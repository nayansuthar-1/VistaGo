<% layout("/layouts/boilerplate") -%>

<div class="row mt-5 mb-5 px-3">
    <div class="col-12 col-lg-8 offset-lg-2">
        <div class="d-flex align-items-center mb-4">
            <a href="/listings/<%= listing._id %>" class="btn btn-outline-dark rounded-circle me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                <i class="fa-solid fa-chevron-left"></i>
            </a>
            <h1 class="fw-bold m-0">Confirm and pay</h1>
        </div>

        <div class="row gy-5">
            <!-- Left Side: Booking Details -->
            <div class="col-12 col-md-7">
                <section class="mb-5">
                    <h4 class="fw-bold mb-4">Your trip</h4>
                    <div class="mb-4">
                        <label for="receipt-email" class="fw-bold mb-2">Receipt Email</label>
                        <input type="email" id="receipt-email" class="form-control py-2 rounded-3 border-dark" value="<%= user.email %>" placeholder="Enter email for receipt" required>
                        <p class="x-small text-muted mt-1">Booking receipt will be sent to this email.</p>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <div>
                            <p class="fw-bold mb-1">Dates</p>
                            <p class="text-muted"><%= new Date(booking.checkIn).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %> – <%= new Date(booking.checkOut).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                        </div>
                        <a href="/listings/<%= listing._id %>" class="text-dark fw-bold text-decoration-underline small">Edit</a>
                    </div>
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="fw-bold mb-1">Guests</p>
                            <p class="text-muted"><%= booking.guests %> <%= booking.guests > 1 ? 'guests' : 'guest' %></p>
                        </div>
                        <a href="/listings/<%= listing._id %>" class="text-dark fw-bold text-decoration-underline small">Edit</a>
                    </div>
                </section>

                <hr class="my-5">

                <section class="mb-5">
                    <h4 class="fw-bold mb-4">Cancellation policy</h4>
                    <p class="text-muted">This booking is <strong>non-refundable</strong>. As per our cancellation policy, no refunds will be issued once the payment is processed. <a href="/policy" target="_blank" class="text-dark fw-bold text-decoration-underline">Learn more</a></p>
                </section>

                <hr class="my-5">

                <section class="mb-5">
                    <h4 class="fw-bold mb-4">Ground rules</h4>
                    <p class="text-muted mb-4">We ask every guest to remember a few simple things about what makes a great guest.</p>
                    <ul class="text-muted small ps-3">
                        <li class="mb-2">Follow the house rules</li>
                        <li>Treat your Host’s home like your own</li>
                    </ul>
                </section>

                <hr class="my-5">

                <div class="d-grid">
                    <form action="/listings/<%= listing._id %>/reserve" method="POST" id="checkout-form">
                        <input type="hidden" name="booking[checkIn]" value="<%= booking.checkIn %>">
                        <input type="hidden" name="booking[checkOut]" value="<%= booking.checkOut %>">
                        <input type="hidden" name="booking[nights]" value="<%= booking.nights %>">
                        <input type="hidden" name="booking[guests]" value="<%= booking.guests %>">
                        <input type="hidden" name="booking[totalPrice]" value="<%= booking.totalPrice %>">
                        
                        <p class="small text-muted mb-3 text-center">By selecting the button below, I agree to the <a href="/terms" target="_blank" class="text-dark fw-bold text-decoration-underline">Host's House Rules</a>, <a href="/policy" target="_blank" class="text-dark fw-bold text-decoration-underline">Ground rules for guests</a>, and <a href="/privacy" target="_blank" class="text-dark fw-bold text-decoration-underline">VistaGo's Re-booking and Refund Policy</a>.</p>
                        
                        <button type="submit" id="main-pay-btn" class="btn btn-brand py-3 fs-5 fw-bold text-white w-100 rounded-3 shadow-sm" style="background: linear-gradient(to right, #e61e4d 0%, #e31c5f 50%, #d70466 100%); border: none;">
                            Confirm and Pay
                        </button>
                    </form>
                </div>
            </div>
            

            <script>
                const checkoutForm = document.getElementById("checkout-form");
                const mainPayBtn = document.getElementById("main-pay-btn");

                checkoutForm.addEventListener("submit", async (e) => {
                    e.preventDefault();
                    mainPayBtn.disabled = true;
                    mainPayBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Initializing...';

                    const formData = new FormData(checkoutForm);
                    const bookingData = {};
                    formData.forEach((value, key) => {
                        // Handle nested booking[field] syntax
                        const match = key.match(/booking\[(\w+)\]/);
                        if (match) {
                            bookingData[match[1]] = value;
                        }
                    });

                    try {
                        const response = await fetch(checkoutForm.action, {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ booking: bookingData })
                        });

                        const data = await response.json();

                        if (data.success) {
                            const options = {
                                key: data.key_id,
                                amount: data.order.amount,
                                currency: data.order.currency,
                                name: "VistaGo",
                                description: "Luxury Stay Booking",
                                order_id: data.order.id,
                                handler: async function (response) {
                                    // Handle payment success
                                    const verifyRes = await fetch("/listings/verify-payment", {
                                        method: "POST",
                                        headers: { "Content-Type": "application/json" },
                                        body: JSON.stringify({
                                            razorpay_order_id: response.razorpay_order_id,
                                            razorpay_payment_id: response.razorpay_payment_id,
                                            razorpay_signature: response.razorpay_signature,
                                            bookingId: data.bookingId,
                                            receiptEmail: document.getElementById("receipt-email").value
                                        })
                                    });

                                    const verifyData = await verifyRes.json();
                                    if (verifyData.success) {
                                        window.location.href = `/listings/bookings/${data.bookingId}/success`;
                                    } else {
                                        alert("Payment verification failed. Please contact support.");
                                        location.reload();
                                    }
                                },
                                prefill: {
                                    name: data.user.name,
                                    email: document.getElementById("receipt-email").value || data.user.email
                                },
                                theme: { color: "#FF385C" }
                            };

                            const rzp1 = new Razorpay(options);
                            rzp1.open();
                        } else {
                            alert(data.message || "Failed to create order");
                        }
                    } catch (err) {
                        console.error(err);
                        alert("An error occurred. Please try again.");
                    } finally {
                        mainPayBtn.disabled = false;
                        mainPayBtn.innerHTML = 'Confirm and Pay';
                    }
                });
            </script>

            <!-- Right Side: Price Summary Card -->
            <div class="col-12 col-md-5">
                <div class="card shadow border p-4 sticky-top rounded-4" style="top: 100px; z-index: 10;">
                    <div class="d-flex gap-3 mb-4">
                        <img src="<%= listing.image.url %>" class="rounded-3 shadow-sm" style="width: 100px; height: 100px; object-fit: cover;">
                        <div>
                            <p class="small mb-1"><%= listing.category %></p>
                            <h6 class="fw-bold mb-1"><%= listing.title %></h6>
                            <p class="small text-muted mb-0"><%= listing.location %>, <%= listing.country %></p>
                        </div>
                    </div>

                    <hr class="mb-4">

                    <h5 class="fw-bold mb-4">Price details</h5>
                    <div class="d-flex justify-content-between mb-3">
                        <span>&#8377;<%= listing.price.toLocaleString() %> x <%= booking.nights %> <%= booking.nights > 1 ? 'nights' : 'night' %></span>
                        <span>&#8377;<%= (listing.price * booking.nights).toLocaleString() %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-decoration-underline">VistaGo service fee</span>
                        <span>&#8377;<%= Math.round(listing.price * booking.nights * 0.14).toLocaleString() %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-decoration-underline">Taxes (GST 18%)</span>
                        <span>&#8377;<%= Math.round(listing.price * booking.nights * 0.18).toLocaleString() %></span>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-between fw-bold fs-5">
                        <span>Total (INR)</span>
                        <span>&#8377;<%= booking.totalPrice.toLocaleString() %></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
