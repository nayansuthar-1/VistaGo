<% layout("/layouts/boilerplate") -%>

<div class="row mt-5 mb-5 px-3">
    <div class="col-12 col-md-8 col-lg-6 offset-md-2 offset-lg-3 text-center">
        <div class="card shadow-lg border-0 rounded-5 p-5">
            <div class="mb-4">
                <div class="success-checkmark d-inline-block bg-success text-white rounded-circle shadow-lg" style="width: 100px; height: 100px; line-height: 100px; font-size: 3rem;">
                    <i class="fa-solid fa-check"></i>
                </div>
            </div>
            
            <h1 class="fw-bold mb-2">Booking Confirmed!</h1>
            <p class="text-muted fs-5 mb-4">Your stay at <strong><%= listing.title %></strong> is successfully booked.</p>
            
            <div class="card bg-light border-0 rounded-4 p-4 text-start mb-4">
                <div class="row gy-3">
                    <div class="col-6">
                        <p class="small text-muted mb-1">Check-in</p>
                        <p class="fw-bold mb-0"><%= new Date(booking.checkIn).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                    </div>
                    <div class="col-6">
                        <p class="small text-muted mb-1">Check-out</p>
                        <p class="fw-bold mb-0"><%= new Date(booking.checkOut).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                    </div>
                    <div class="col-6">
                        <p class="small text-muted mb-1">Guests</p>
                        <p class="fw-bold mb-0"><%= booking.guests %> guests</p>
                    </div>
                    <div class="col-6">
                        <p class="small text-muted mb-1">Total Paid</p>
                        <p class="fw-bold mb-0">&#8377;<%= booking.totalPrice.toLocaleString() %></p>
                    </div>
                </div>
            </div>

            <div class="card border border-2 border-dashed rounded-4 p-3 mb-4">
                <p class="small text-muted mb-1">Reservation ID</p>
                <p class="fw-bold mb-0 text-uppercase letter-spacing-1"><%= booking._id %></p>
            </div>

            <p class="small text-muted mb-5">A confirmation email has been sent to your registered account. You can manage your booking in your dashboard.</p>

            <div class="d-flex flex-column gap-3">
                <a href="/account/bookings" class="btn btn-brand py-3 fw-bold text-white shadow-sm rounded-3">View My Trips</a>
                <a href="/listings" class="btn btn-outline-dark py-3 fw-bold rounded-3">Explore More Stays</a>
            </div>
        </div>
    </div>
</div>

<style>
    .success-checkmark {
        animation: scaleIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .letter-spacing-1 {
        letter-spacing: 1px;
    }
    @keyframes scaleIn {
        from { transform: scale(0); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }
</style>
