<% layout("/layouts/boilerplate") -%>

<div class="row mt-4 mb-5">
  <div class="col-12 col-md-10 offset-md-1">
    <h2 class="fw-bold mb-4">My Wishlists</h2>

    <% if (user.wishlist && user.wishlist.length > 0) { %>
      <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 gx-4 gy-4">
        <% for (let listing of user.wishlist ){ 
            let avgRating = "New";
            if (listing.reviews && listing.reviews.length > 0) {
              let total = 0;
              for (let r of listing.reviews) {
                total += r.rating;
              }
              avgRating = (total / listing.reviews.length).toFixed(1);
            }
        %>
        <div class="col">
          <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card listing-card h-100 border-0">
              <div class="card-img-wrapper">
                <img
                  src="<%= listing.image.url %>"
                  class="card-img-top"
                  alt="<%= listing.title %>"
                />
                <div class="card-img-overlay">
                  <i class="fa-solid fa-heart heart-icon liked text-brand" data-id="<%= listing._id %>"></i>
                </div>
              </div>
              <div class="card-body px-0">
                <div class="d-flex justify-content-between align-items-baseline mt-2 mb-1">
                  <p class="card-title fw-bold m-0 text-truncate" style="max-width: 75%; font-size: 0.95rem;"><%= listing.location %>, <%= listing.country %></p>
                  <div class="card-rating d-flex align-items-center flex-shrink-0">
                    <i class="fa-solid fa-star me-1" style="font-size: 0.75rem;"></i><span style="font-size: 0.9rem;"><%= avgRating %></span>
                  </div>
                </div>
                <p class="card-text text-muted mb-0" style="font-size: 0.9rem;">Saved to wishlist</p>
                <p class="card-text mt-1" style="font-size: 0.95rem;">
                  <span class="fw-bold">&#8377; <%= listing.price ? listing.price.toLocaleString() : "N/A" %></span> night
                </p>
              </div>
            </div>
          </a>
        </div>
        <% } %>
      </div>
    <% } else { %>
      <div class="text-center py-5 bg-light rounded-4 border mt-4">
        <i class="fa-regular fa-heart fs-1 text-muted mb-3"></i>
        <h4 class="fw-bold">No saved listings yet</h4>
        <p class="text-muted mb-4">Click the heart icon on any listing to save it here.</p>
        <a href="/listings" class="btn btn-brand text-white px-5 py-2 fw-bold rounded-3" style="background: linear-gradient(to right, #e61e4d 0%, #e31c5f 50%, #d70466 100%);">Explore Listings</a>
      </div>
    <% } %>
  </div>
</div>
