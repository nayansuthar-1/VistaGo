<% layout("/layouts/boilerplate") -%>

<div class="row mt-5 mb-5">
  <div class="col-12 col-md-8 col-lg-6 offset-md-2 offset-lg-3">
    
    <div class="mb-5">
      <h2 class="fw-bold mb-2">Tell us about your place</h2>
      <p class="text-muted fs-5">In this step, we'll ask you which type of property you have and if guests will book the entire place or just a room.</p>
    </div>

    <div class="card shadow-sm border-0 rounded-4 p-4 p-md-5 bg-white">
      <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        
        <!-- 1. Basics -->
        <h4 class="fw-bold mb-4">The basics</h4>
        
        <div class="mb-4">
          <label for="title" class="form-label fw-bold text-dark mb-1">Catchy Title</label>
          <p class="text-muted small mb-2">Short titles work best. Have fun with it—you can always change it later.</p>
          <input
            name="listing[title]"
            id="title"
            placeholder="e.g. Cozy Beachfront Cottage"
            type="text"
            class="form-control form-control-lg rounded-3 fs-6 p-3"
            required
          />
          <div class="invalid-feedback">Please enter a catchy title.</div>
        </div>

        <div class="mb-5">
          <label for="description" class="form-label fw-bold text-dark mb-1">Create your description</label>
          <p class="text-muted small mb-2">Share what makes your place special.</p>
          <textarea 
            name="listing[description]" 
            id="description"
            required 
            placeholder="You'll have a great time at this comfortable place to stay..." 
            class="form-control rounded-3 p-3" 
            rows="5"
          ></textarea>
          <div class="invalid-feedback">Please write a short description.</div>
        </div>

        <hr class="mb-5">

        <!-- 2. Location -->
        <h4 class="fw-bold mb-4">Location</h4>
        
        <div class="mb-4">
          <label for="country" class="form-label fw-bold text-dark mb-1">Country / Region</label>
          <input
            name="listing[country]"
            id="country"
            placeholder="e.g. United States"
            type="text"
            class="form-control form-control-lg rounded-3 fs-6 p-3"
            required
          />
          <div class="invalid-feedback">Please specify the country.</div>
        </div>

        <div class="mb-5">
          <label for="location" class="form-label fw-bold text-dark mb-1">City / Town</label>
          <input
            name="listing[location]"
            id="location"
            placeholder="e.g. Malibu"
            type="text"
            class="form-control form-control-lg rounded-3 fs-6 p-3"
            required
          />
          <div class="invalid-feedback">Please specify the location.</div>
        </div>

        <div class="mb-5">
          <label for="category" class="form-label fw-bold text-dark mb-1">Category</label>
          <p class="text-muted small mb-2">What kind of property is this?</p>
          <select 
            name="listing[category]" 
            id="category" 
            class="form-select form-control-lg rounded-3 fs-6 p-3" 
            required
          >
            <option value="" disabled selected>Select a category</option>
            <option value="Trending">Trending</option>
            <option value="Rooms">Rooms</option>
            <option value="Iconic cities">Iconic cities</option>
            <option value="Mountains">Mountains</option>
            <option value="Castles">Castles</option>
            <option value="Amazing pools">Amazing pools</option>
            <option value="Camping">Camping</option>
            <option value="Farms">Farms</option>
            <option value="Arctic">Arctic</option>
            <option value="Domes">Domes</option>
            <option value="Boats">Boats</option>
          </select>
          <div class="invalid-feedback">Please select a category.</div>
        </div>

        <hr class="mb-5">

        <!-- 3. Amenities -->
        <h4 class="fw-bold mb-4">What this place offers</h4>
        <p class="text-muted small mb-3">Select the amenities available at your place.</p>
        
        <div class="row row-cols-1 row-cols-sm-2 mb-5">
          <% 
            const amenityOptions = [
              { name: "Wifi", icon: "fa-wifi" },
              { name: "Kitchen", icon: "fa-kitchen-set" },
              { name: "AC", icon: "fa-snowflake" },
              { name: "Free parking", icon: "fa-car" },
              { name: "TV", icon: "fa-tv" },
              { name: "Pool", icon: "fa-person-swimming" },
              { name: "Gym", icon: "fa-dumbbell" },
              { name: "Workspace", icon: "fa-briefcase" },
              { name: "Lake view", icon: "fa-water" },
              { name: "Mountain view", icon: "fa-mountain" }
            ];
          %>
          <% amenityOptions.forEach(amenity => { %>
            <div class="col mb-3">
              <div class="form-check d-flex align-items-center gap-3 border p-3 rounded-3 hover-bg-light cursor-pointer">
                <input 
                  class="form-check-input ms-0 mt-0" 
                  type="checkbox" 
                  name="listing[amenities]" 
                  value="<%= amenity.name %>" 
                  id="amenity-<%= amenity.name.replace(/\s+/g, '-').toLowerCase() %>"
                >
                <label class="form-check-label flex-grow-1 cursor-pointer" for="amenity-<%= amenity.name.replace(/\s+/g, '-').toLowerCase() %>">
                  <i class="fa-solid <%= amenity.icon %> me-2 text-muted"></i> <%= amenity.name %>
                </label>
              </div>
            </div>
          <% }) %>
        </div>

        <hr class="mb-5">

        <!-- 3. Photos -->
        <h4 class="fw-bold mb-4">Add some photos of your house</h4>
        <p class="text-muted small mb-3">You'll need at least one photo to get started. You can add more or make changes later.</p>
        
        <div class="mb-5 border rounded-4 p-4 bg-light text-center">
          <i class="fa-regular fa-images fs-1 text-muted mb-3 d-block"></i>
          
          <div class="mb-4 text-start">
            <label for="listingImage" class="form-label fw-bold text-dark mb-1">Upload from your device</label>
            <input
              name="listingImage"
              id="listingImage"
              type="file"
              class="form-control form-control-lg rounded-3 fs-6 bg-white"
              accept="image/*"
            />
          </div>
          
          <div class="d-flex align-items-center mb-4">
            <hr class="flex-grow-1">
            <span class="px-3 text-muted small fw-bold text-uppercase">or</span>
            <hr class="flex-grow-1">
          </div>

          <div class="text-start">
            <label for="imageUrl" class="form-label fw-bold text-dark mb-1">Paste a web link</label>
            <input
              name="listing[image]"
              id="imageUrl"
              placeholder="https://example.com/photo.jpg"
              type="text"
              class="form-control form-control-lg rounded-3 fs-6 p-3 bg-white"
            />
          </div>
        </div>

        <hr class="mb-5">

        <!-- 4. Pricing -->
        <h4 class="fw-bold mb-4">Now, set your price</h4>
        <p class="text-muted small mb-3">You can change it anytime.</p>
        
        <div class="mb-5">
          <div class="input-group">
            <span class="input-group-text bg-white border-end-0 rounded-start-4 ps-4 fs-4 fw-bold text-muted">&#8377;</span>
            <input
              name="listing[price]"
              id="price"
              placeholder="0"
              class="form-control form-control-lg border-start-0 rounded-end-4 fs-1 py-3 fw-bold shadow-none"
              style="outline: none; box-shadow: none;"
              required
            />
          </div>
          <div class="invalid-feedback mt-2">Please set a valid nightly price.</div>
        </div>

        <!-- Submit -->
        <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top">
          <a href="/listings" class="text-dark fw-bold text-decoration-underline">Cancel</a>
          <button class="btn btn-brand px-5 py-3 rounded-3 fw-bold text-white fs-5" style="background: linear-gradient(to right, #e61e4d 0%, #e31c5f 50%, #d70466 100%);">Publish Listing</button>
        </div>
      </form>
    </div>
  </div>
</div>
